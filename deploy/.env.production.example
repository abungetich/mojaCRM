# Copy to /etc/mojacrm/.env.production on the APP VPS and `chmod 600` it.
# Never commit the real file.
#
# This one file is used as env_file for postgres, api, worker, AND seed
# (docker-compose.contabo.yml) — it holds both the Postgres container's own
# POSTGRES_* vars and the app's DATABASE_URL pointing back at that same
# container by service name.

PORT=8080

# Postgres runs as its own container on this VPS (see docker-compose.contabo.yml).
POSTGRES_USER=mojacrm
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=mojacrm

# Internal docker-network hostname, not a public address — sslmode=disable
# is fine since this traffic never leaves the VPS's docker network. Uses
# "mojacrm-postgres" (not the generic "postgres") because the api container
# also joins the shared amac-net Caddy network, where a generic name could
# collide with another app's identically-named service/container.
DATABASE_URL=postgres://mojacrm:CHANGE_ME_strong_db_password@mojacrm-postgres:5432/mojacrm?sslmode=disable

# Redis stays local to this VPS (container name from docker-compose.contabo.yml).
REDIS_ADDR=redis:6379

JWT_SECRET=CHANGE_ME_long_random_jwt_secret

# Scoped to the app's own host — the marketing site on the apex domain
# doesn't need (and shouldn't share) this cookie.
COOKIE_DOMAIN=app.mojacrm.com
COOKIE_SECURE=true

ALLOW_ORIGIN=https://app.mojacrm.com

# Platform admin seeded by `--profile seed run --rm seed`. Only affects the
# first run (the seed command skips creating it if the email already
# exists). SEED_DEMO_TENANT=false skips the fake Acme demo tenant/owner —
# leave it true only for a staging/demo box.
#
# NOTE: docker compose collapses "$$" -> "$" when it reads an env_file, so
# if the password contains a literal $, write it doubled here (e.g. a
# password ending in one $ needs $$ in this file, one ending in $$ needs
# $$$$) or Compose will silently drop characters.
PLATFORM_ADMIN_EMAIL=admin@mojacrm.test
PLATFORM_ADMIN_NAME=Platform Admin
PLATFORM_ADMIN_PASSWORD=CHANGE_ME
SEED_DEMO_TENANT=false

# Optional
SENTRY_DSN=

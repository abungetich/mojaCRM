# Append this block to the shared Caddyfile at /opt/amacplc/Caddyfile on the
# app VPS (the same box already running PropSense's amac-caddy).
#
# The Caddyfile is bind-mounted as a single file into the amac-caddy
# container — edit with an append / in-place write (NOT `sed -i`, which
# swaps the inode and leaves the running container looking at the stale
# file). After editing, reload:
#   docker exec amac-caddy caddy reload --config /etc/caddy/Caddyfile
#
# amac-caddy reaches apps by CONTAINER NAME on the shared docker network
# `amacplc_amac-net` (not 127.0.0.1 — inside the container that's caddy
# itself). mojacrm's `api` service joins that network via
# deploy/docker-compose.contabo.yml.
#
# Same split as PropSense: the product lives on its own subdomain, the
# apex + www are reserved for a marketing site.

# --- The app ---
# /api/docs (Swagger UI + the OpenAPI spec) is gated with HTTP Basic Auth —
# it's not meant to be public. Generate the hash with:
#   docker exec amac-caddy caddy hash-password --plaintext '<a real password>'
# and paste it below (the username can be anything).
app.mojacrm.com {
    encode zstd gzip

    basic_auth /api/docs* {
        admin $2a$14$O62qndouzSzeS0mxMgJnT.boCU0ht.Wn7Mwv4dmX.XJXkJHJZQQhm
    }

    reverse_proxy mojacrm-api-1:8080
}

# --- Apex + www: no marketing site built yet, so redirect to the app for
# now. Once a marketing site exists, replace this block with a
# `reverse_proxy <marketing-container>:<port>` like PropSense's. ---
mojacrm.com, www.mojacrm.com {
    encode zstd gzip
    redir https://app.mojacrm.com{uri} permanent
}
